{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.visionstudio.app",
  "productName": "Vision Studio",
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "!backend/**/*",
    "!resources/**/*",
    "!**/*.pyc",
    "!**/*.pyo",
    "!**/*.pyd"
  ],
  "extraResources": [
    {
      "from": "resources/",
      "to": ".",
      "filter": ["**/*"]
    },
    {
      "from": "backend/",
      "to": "backend-source/",
      "filter": ["**/*", "!venv/**/*", "!build/**/*", "!dist/**/*", "!__pycache__/**/*", "!*.pyc"]
    }
  ],
  "win": {
    "target": [
      {
        "target": "portable",
        "arch": ["x64"]
      },
      {
        "target": "zip",
        "arch": ["x64"]
      }
    ],
    "icon": "build/icon.ico",
    "publisherName": "Vision Studio Team",
    "verifyUpdateCodeSignature": false,
    "requestedExecutionLevel": "asInvoker"
  },
  "compression": "store",
  "portable": {
    "artifactName": "Vision-Studio-Portable-${version}.exe"
  },
  "publish": {
    "provider": "github",
    "owner": "yourusername",
    "repo": "vision-studio",
    "releaseType": "release"
  }
}
