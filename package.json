{
  "name": "vision-studio",
  "private": true,
  "version": "2.5.0",
  "type": "module",
  "main": "dist-electron/main.mjs",
  "description": "Professional AI Image & Video Generation",
  "author": {
    "name": "Vision Studio Team",
    "email": "hello@visionstudio.app"
  },
  "homepage": "https://github.com/yourusername/vision-studio",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run src/features src/utils src/store electron/services",
    "test:component": "vitest run src/components",
    "test:integration": "vitest run tests/integration",
    "test:all": "vitest run",
    "lint": "eslint src electron --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "preview": "electron .",
    "package": "electron-builder",
    "package:win": "electron-builder --win",
    "package:win:signed": "node scripts/verify-release-signing.cjs --package-win",
    "package:mac": "electron-builder --mac",
    "package:linux": "electron-builder --linux",
    "package:signed": "npm run build && npm run package:win:signed",
    "release:signing:check": "node scripts/verify-release-signing.cjs",
    "postinstall": "electron-builder install-app-deps",
    "clean": "npx rimraf dist dist-electron release resources",
    "clean:all": "npx rimraf dist dist-electron release resources node_modules backend/venv backend/build backend/dist",
    "build:backend": "node build-backend.cjs",
    "build:windows": "node scripts/build-windows.cjs",
    "build:windows:full": "npm run build:backend && npm run build:windows",
    "build:all": "npm run build:backend && npm run package",
    "create:icon": "powershell -ExecutionPolicy Bypass -File scripts/create-icon.ps1",
    "test:build": "npm run build:windows && echo 'Build complete! Check release/ folder'",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "test:a11y": "npx playwright test accessibility",
    "test:visual": "npx playwright test tests/e2e/visual",
    "test:visual:update": "npx playwright test tests/e2e/visual --update-snapshots",
    "test:perf": "playwright test tests/e2e/performance",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@floating-ui/react": "^0.27.19",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/ibm-plex-sans-condensed": "^5.2.8",
    "@tanstack/react-virtual": "^3.13.21",
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "dockview": "^5.2.0",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.9",
    "framer-motion": "^12.4.7",
    "konva": "^10.2.0",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-konva": "^19.2.2",
    "react-router-dom": "^7.2.0",
    "tailwind-merge": "^3.0.2",
    "ws": "^8.18.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.0.8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.3",
    "msw": "^2.12.10",
    "postcss": "^8.5.3",
    "rimraf": "^5.0.0",
    "tailwindcss": "^4.0.8",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.1.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^3.2.4"
  }
}
