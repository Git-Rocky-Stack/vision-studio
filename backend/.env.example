# Vision Studio Backend Configuration

# ComfyUI Server URL (optional - uses direct generation if not set)
COMFYUI_URL=http://127.0.0.1:8188

# HuggingFace Token (for downloading gated models like FLUX)
HUGGINGFACE_TOKEN=your_token_here

# Model cache directory
MODELS_DIR=./models
OUTPUT_DIR=./outputs

# Server configuration
HOST=0.0.0.0
PORT=8000

# GPU settings
CUDA_VISIBLE_DEVICES=0
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512

# Debug mode
DEBUG=false
